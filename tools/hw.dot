digraph hello_world {
   rankdir = LR;
   node [shape = box, style = rounded];
   __start [shape = point];
   __start -> ESTABLISHED;
   ESTABLISHED -> FIN_WAIT_1 [label="E_RELEASE [ALWAYS] / SEND_FIN"];
   FIN_WAIT_1 -> FIN_WAIT_2 [label="E_ACK [IS_VALID] / NOTHING"];
   FIN_WAIT_2 -> TIMED_WAIT [label="E_FIN [IS_VALID] / SEND_ACK"];
   TIMED_WAIT -> CLOSED [label="E_TIMEOUT [ALWAYS] / NOTHING"];
}
