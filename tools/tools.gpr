with "../sml_ada.gpr";

--  Build the generator: `alr exec -- gprbuild -P tools/tools.gpr`, then run
--  bin/gen from a directory where you want the generated files.
project Tools is

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("gen.adb", "check.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-gnatwa", "-gnat2022");
   end Compiler;

end Tools;
