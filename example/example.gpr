with "../sml_ada.gpr";

project Example is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("hello_world.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g", "-gnata", "-gnatwa", "-gnatwe", "-gnat2022");
   end Compiler;

end Example;
