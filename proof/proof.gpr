with "../sml.gpr";

--  SPARK proof target.  Not built by `alr build`; analysed with
--  `alr exec -- gnatprove -P proof/proof.gpr`.  It instantiates the engine and
--  its operators (Sml.Machines + Operators) for a concrete instance.
project Proof is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata");
   end Compiler;

end Proof;
